# TwinMind Groq API Configuration Template
# Copy this file to .env and fill in your unique Groq API Key to enable real-time AI.

# Your Groq API Key (Target model: whisper-large-v3 & openai/gpt-oss-120b)
GROQ_API_KEY=your_key_here

# Default transcription cadence (Seconds)
MOCK_CADENCE_SECONDS=30

# System environment (development | production)
NODE_ENV=production
