{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Real-time AI CopilotSuggestionEngineInput",
    "type": "object",
    "required": [
        "current_time",
        "refresh_mode",
        "recent_window_seconds",
        "transcript_recent",
        "previous_suggestion_batches"
    ],
    "properties": {
        "current_time": {
            "type": "string",
            "format": "date-time"
        },
        "refresh_mode": {
            "type": "string",
            "enum": [
                "auto",
                "manual"
            ]
        },
        "recent_window_seconds": {
            "type": "integer",
            "minimum": 15,
            "maximum": 180
        },
        "full_transcript_available": {
            "type": "boolean",
            "default": true
        },
        "transcript_recent": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": [
                    "chunk_id",
                    "start_ts",
                    "end_ts",
                    "text"
                ],
                "properties": {
                    "chunk_id": {
                        "type": "string"
                    },
                    "speaker": {
                        "type": "string"
                    },
                    "start_ts": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "end_ts": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "text": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "additionalProperties": false
            }
        },
        "transcript_session_summary": {
            "type": "string",
            "default": ""
        },
        "clicked_suggestions": {
            "type": "array",
            "default": [],
            "items": {
                "type": "object",
                "required": [
                    "suggestion_id",
                    "clicked_at"
                ],
                "properties": {
                    "suggestion_id": {
                        "type": "string"
                    },
                    "clicked_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "additionalProperties": false
            }
        },
        "previous_suggestion_batches": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "batch_id",
                    "created_at",
                    "suggestions"
                ],
                "properties": {
                    "batch_id": {
                        "type": "string"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "phase": {
                        "type": "string",
                        "enum": [
                            "early_exploration",
                            "mid_discussion_tradeoff",
                            "decision_next_steps"
                        ]
                    },
                    "suggestions": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": [
                                "id",
                                "type",
                                "preview",
                                "topic_signature"
                            ],
                            "properties": {
                                "id": {
                                    "type": "string"
                                },
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "question",
                                        "answer",
                                        "clarification",
                                        "fact_check",
                                        "insight",
                                        "summary"
                                    ]
                                },
                                "preview": {
                                    "type": "string"
                                },
                                "topic_signature": {
                                    "type": "string"
                                },
                                "based_on": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            },
                            "additionalProperties": false
                        }
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "additionalProperties": false
}
