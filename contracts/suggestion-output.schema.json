{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Real-time AI CopilotSuggestionEngineOutput",
    "type": "object",
    "required": [
        "current_phase",
        "recent_context_summary",
        "suggestions"
    ],
    "properties": {
        "current_phase": {
            "type": "string",
            "enum": [
                "early_exploration",
                "mid_discussion_tradeoff",
                "decision_next_steps"
            ]
        },
        "recent_context_summary": {
            "type": "string",
            "minLength": 1
        },
        "suggestions": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "type",
                    "preview",
                    "why_now",
                    "based_on",
                    "topic_signature",
                    "novelty_basis",
                    "expand_seed",
                    "confidence"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string",
                        "enum": [
                            "question",
                            "answer",
                            "clarification",
                            "fact_check",
                            "insight",
                            "summary"
                        ]
                    },
                    "preview": {
                        "type": "string",
                        "minLength": 8
                    },
                    "why_now": {
                        "type": "string",
                        "minLength": 8
                    },
                    "based_on": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                            "type": "string"
                        }
                    },
                    "topic_signature": {
                        "type": "string",
                        "minLength": 3
                    },
                    "novelty_basis": {
                        "type": "string",
                        "minLength": 8
                    },
                    "expand_seed": {
                        "type": "string",
                        "minLength": 8
                    },
                    "confidence": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "additionalProperties": false
}
